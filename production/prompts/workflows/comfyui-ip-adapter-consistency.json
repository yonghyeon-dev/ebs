{
  "_meta": {
    "title": "IP-Adapter 캐릭터 일관성 워크플로우",
    "description": "레퍼런스 이미지 생성 후 IP-Adapter를 적용하여 캐릭터 일관성을 유지하며 추가 이미지를 생성하는 템플릿 워크플로우. animagineXL v3.1 체크포인트 기반. 모든 캐릭터에 범용 사용.",
    "version": "2.0.0",
    "checkpoint": "animagineXL31_v31.safetensors",
    "usage": "1) 기본 워크플로우(choeun/grandpa/mungyi)로 ref01(정면) 생성 -> 2) 만족스러운 결과를 reference_image로 로드 -> 3) 이 워크플로우에서 추가 앵글/표정 생성"
  },

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "animagineXL31_v31.safetensors"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "sdxl_vae.safetensors"
    }
  },

  "5": {
    "class_type": "LoadImage",
    "_meta": { "title": "레퍼런스 이미지 로드 (ref01 정면 결과물)" },
    "inputs": {
      "image": "reference_image.png"
    }
  },
  "6": {
    "class_type": "IPAdapterModelLoader",
    "_meta": { "title": "IP-Adapter 모델 로드" },
    "inputs": {
      "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors"
    }
  },
  "7": {
    "class_type": "CLIPVisionLoader",
    "_meta": { "title": "CLIP Vision 모델 로드" },
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "8": {
    "class_type": "IPAdapterAdvanced",
    "_meta": { "title": "IP-Adapter 적용 -- weight 조절 가이드 참조" },
    "inputs": {
      "ipadapter": ["6", 0],
      "clip_vision": ["7", 0],
      "image": ["5", 0],
      "model": ["1", 0],
      "weight": 0.7,
      "weight_type": "linear",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },

  "10": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive -- 여기에 생성할 이미지의 프롬프트를 입력" },
    "inputs": {
      "clip": ["1", 1],
      "text": "YOUR_POSITIVE_PROMPT_HERE"
    }
  },
  "11": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" },
    "inputs": {
      "clip": ["1", 1],
      "text": "YOUR_NEGATIVE_PROMPT_HERE"
    }
  },
  "12": {
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "해상도 -- 생성 이미지에 맞게 조절" },
    "inputs": { "width": 896, "height": 1152, "batch_size": 1 }
  },
  "13": {
    "class_type": "KSampler",
    "_meta": { "title": "KSampler -- IP-Adapter 모델 연결" },
    "inputs": {
      "model": ["8", 0],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "latent_image": ["12", 0],
      "seed": 0,
      "steps": 28,
      "cfg": 6.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    }
  },
  "14": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["13", 0], "vae": ["2", 0] }
  },
  "15": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["14", 0],
      "filename_prefix": "ip-adapter-output"
    }
  }
}
